{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Floating Todo",
  "version": "0.1.0",
  "identifier": "com.hiro.floatingtodo",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Floating Todo",
        "width": 380,
        "height": 640,
        "minWidth": 120,
        "minHeight": 72,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "resizable": false,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}